@page "/signin"
@using Podium.Shared.Services.Api
@using Podium.Shared.Services.State
@inject IPodiumApiClient ApiClient
@inject AuthStateService AuthState
@inject LanguageStateService LangState
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Auth> L

<PageTitle>Sign In - Podium</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <h2>@L["SignIn_Title"]</h2>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" role="alert">@errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success" role="status">@successMessage</div>
        }

        <div class="auth-tabs" role="tablist">
            <button role="tab" aria-selected="@(authMethod == "password")" class="@(authMethod == "password" ? "active" : "")" @onclick="@(() => authMethod = "password")">
                @L["SignIn_Tab_Password"]
            </button>
            <button role="tab" aria-selected="@(authMethod == "email")" class="@(authMethod == "email" ? "active" : "")" @onclick="@(() => authMethod = "email")">
                @L["SignIn_Tab_EmailCode"]
            </button>
        </div>

        @if (authMethod == "password")
        {
            <div class="auth-form">
                <div class="form-group">
                    <label for="signin-email">@L["SignIn_Label_EmailOrUsername"]</label>
                    <input id="signin-email" type="text" class="form-control" @bind="emailOrUsername" placeholder="@L["SignIn_Placeholder_EmailOrUsername"]" autocomplete="username" />
                </div>

                <div class="form-group">
                    <label for="signin-password">@L["SignIn_Label_Password"]</label>
                    <input id="signin-password" type="password" class="form-control" @bind="password" placeholder="@L["SignIn_Placeholder_Password"]" autocomplete="current-password" />
                </div>

                <button class="btn btn-primary w-100" @onclick="SignInWithPassword" disabled="@isLoading">
                    @if (isLoading) { <span>@L["SignIn_Btn_SigningIn"]</span> }
                    else { <span>@L["SignIn_Btn_SignIn"]</span> }
                </button>
            </div>
        }
        else
        {
            @if (!otpSent)
            {
                <div class="auth-form">
                    <div class="form-group">
                        <label for="signin-otp-email">@L["SignIn_Label_EmailOrUsername"]</label>
                        <input id="signin-otp-email" type="text" class="form-control" @bind="emailOrUsernameForOtp" placeholder="@L["SignIn_Placeholder_EmailOrUsername"]" autocomplete="username" />
                    </div>

                    <button class="btn btn-primary w-100" @onclick="SendOtp" disabled="@isLoading">
                        @if (isLoading) { <span>@L["SignIn_Btn_Sending"]</span> }
                        else { <span>@L["SignIn_Btn_SendCode"]</span> }
                    </button>
                </div>
            }
            else
            {
                <div class="auth-form">
                    <p class="text-center">@L["SignIn_SentTo"] <strong>@displayEmail</strong></p>

                    <div class="form-group">
                        <label for="signin-otp-code">@L["SignIn_Label_Code"]</label>
                        <input id="signin-otp-code" type="text" class="form-control" @bind="otpCode" placeholder="@L["SignIn_Placeholder_Code"]" maxlength="6" autocomplete="one-time-code" inputmode="numeric" />
                    </div>

                    <button class="btn btn-primary w-100" @onclick="VerifyOtp" disabled="@isLoading">
                        @if (isLoading) { <span>@L["SignIn_Btn_Verifying"]</span> }
                        else { <span>@L["SignIn_Btn_Verify"]</span> }
                    </button>

                    <button class="btn btn-link w-100" @onclick="ResetOtp">@L["SignIn_Btn_SendCode"]</button>
                </div>
            }
        }

        <div class="auth-footer">
            <p>@L["SignIn_NoAccount"] <a href="/signup">@L["SignIn_SignUpLink"]</a></p>
        </div>
    </div>
</div>

@code {
private string authMethod = "password";
private string emailOrUsername = "";
private string emailOrUsernameForOtp = "";
private string email = "";
private string password = "";
private string otpCode = "";
private bool otpSent = false;
private bool isLoading = false;
private string? errorMessage;
private string? successMessage;
private string displayEmail = ""; // For showing which email received the code

private async Task SignInWithPassword()
{
    errorMessage = null;
    successMessage = null;

    if (string.IsNullOrWhiteSpace(emailOrUsername) || string.IsNullOrWhiteSpace(password))
    {
        errorMessage = L["SignIn_Required"];
        return;
    }

    isLoading = true;
    try
    {
        var response = await ApiClient.SignInAsync(emailOrUsername, password);
        if (response.Success && response.Data != null)
        {
            // Use the sessionId returned from API
            await AuthState.SetAuthStateAsync(response.Data.UserId, response.Data.Username, response.Data.SessionId);

            // Apply user's DB language preference
            var dbLang = response.Data.LanguageCode;
            var needsReload = !string.IsNullOrEmpty(dbLang) && dbLang != LangState.CurrentLanguageCode;
            if (needsReload)
            {
                await LangState.SetLanguageAsync(dbLang!);
                try { await JSRuntime.InvokeVoidAsync("podiumCulture.set", dbLang); } catch { }
            }

            Navigation.NavigateTo("/", forceLoad: needsReload && OperatingSystem.IsBrowser());
        }
        else
        {
            errorMessage = response.Error ?? L["SignIn_Failed"];
        }
    }
    catch (Exception ex)
    {
        errorMessage = ex.Message;
    }
    finally
    {
        isLoading = false;
    }
}

private async Task SendOtp()
{
    errorMessage = null;
    successMessage = null;

    if (string.IsNullOrWhiteSpace(emailOrUsernameForOtp))
    {
        errorMessage = L["SignIn_EnterEmailOrUsername"];
        return;
    }

    isLoading = true;
    try
    {
        var response = await ApiClient.SendOtpAsync(emailOrUsernameForOtp);
        if (response.Success && response.Data != null)
        {
            otpSent = true;
            // Use the ACTUAL email returned from the API for verification
            email = response.Data.Email;
            displayEmail = response.Data.Email;
            successMessage = L["SignIn_OtpSent"];
        }
        else
        {
            errorMessage = response.Error ?? L["SignIn_OtpFailed"];
        }
    }
    catch (Exception ex)
    {
        errorMessage = $"Error: {ex.Message}";
    }
    finally
    {
        isLoading = false;
    }
}

    private async Task VerifyOtp()
    {
        errorMessage = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(otpCode))
        {
            errorMessage = L["SignIn_EnterCode"];
            return;
        }

        isLoading = true;
        try
        {
            var response = await ApiClient.VerifyOtpAsync(email, otpCode);
            if (response.Success && response.Data != null)
            {
                // Use the sessionId returned from API
                await AuthState.SetAuthStateAsync(response.Data.UserId, response.Data.Username, response.Data.SessionId);

                // Apply user's DB language preference
                var dbLang = response.Data.LanguageCode;
                var needsReload = !string.IsNullOrEmpty(dbLang) && dbLang != LangState.CurrentLanguageCode;
                if (needsReload)
                {
                    await LangState.SetLanguageAsync(dbLang!);
                    try { await JSRuntime.InvokeVoidAsync("podiumCulture.set", dbLang); } catch { }
                }

                Navigation.NavigateTo("/", forceLoad: needsReload && OperatingSystem.IsBrowser());
            }
            else
            {
                errorMessage = response.Error ?? L["SignIn_InvalidCode"];
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ResetOtp()
    {
        otpSent = false;
        otpCode = "";
        errorMessage = null;
        successMessage = null;
    }
}
