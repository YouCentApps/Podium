@page "/signup"
@using Podium.Shared.Services.Api
@using Podium.Shared.Services.State
@inject IPodiumApiClient ApiClient
@inject AuthStateService AuthState
@inject LanguageStateService LangState
@inject NavigationManager Navigation
@inject IStringLocalizer<Auth> L

<PageTitle>Sign Up - Podium</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <h1>@L["SignUp_Title"]</h1>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" role="alert">@errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success" role="status">@successMessage</div>
        }

        @if (!verificationSent)
        {
            <div class="auth-form">
                <div class="form-group">
                    <label for="signup-username">@L["SignUp_Label_Username"] <span class="text-danger">@L["SignUp_Required"]</span></label>
                    <input id="signup-username" type="text" class="form-control" @bind="username" placeholder="@L["SignUp_Placeholder_Username"]" maxlength="50" autocomplete="username" />
                    <small class="form-text text-muted">@L["SignUp_Hint_Username"]</small>
                </div>

                <div class="form-group">
                    <label for="signup-authmethod">@L["SignUp_Label_AuthMethod"] <span class="text-danger">@L["SignUp_Required"]</span></label>
                    <select id="signup-authmethod" class="form-control" @bind="preferredAuthMethod">
                        <option value="Both">@L["SignUp_Method_Both"]</option>
                        <option value="Password">@L["SignUp_Method_Password"]</option>
                        <option value="Email">@L["SignUp_Method_Email"]</option>
                    </select>
                </div>

                @if (preferredAuthMethod == "Email" || preferredAuthMethod == "Both")
                {
                    <div class="form-group">
                        <label for="signup-email">@L["SignUp_Label_Email"] <span class="text-danger">@L["SignUp_Required"]</span></label>
                        <input id="signup-email" type="email" class="form-control" @bind="email" placeholder="@L["SignUp_Placeholder_Email"]" autocomplete="email" />
                        <small class="form-text text-muted">@L["SignUp_Hint_EmailRequired"]</small>
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label for="signup-email-optional">@L["SignUp_Label_EmailOptional"]</label>
                        <input id="signup-email-optional" type="email" class="form-control" @bind="email" placeholder="@L["SignUp_Placeholder_Email"]" autocomplete="email" />
                    </div>
                }

                @if (preferredAuthMethod == "Password" || preferredAuthMethod == "Both")
                {
                    <div class="form-group">
                        <label for="signup-password">@L["SignUp_Label_Password"] <span class="text-danger">@L["SignUp_Required"]</span></label>
                        <input id="signup-password" type="password" class="form-control" @bind="password" placeholder="@L["SignUp_Placeholder_Password"]" maxlength="100" autocomplete="new-password" />
                        <small class="form-text text-muted">@L["SignUp_Hint_Password"]</small>
                    </div>

                    <div class="form-group">
                        <label for="signup-confirm-password">@L["SignUp_Label_ConfirmPassword"] <span class="text-danger">@L["SignUp_Required"]</span></label>
                        <input id="signup-confirm-password" type="password" class="form-control" @bind="confirmPassword" placeholder="@L["SignUp_Placeholder_ConfirmPassword"]" maxlength="100" autocomplete="new-password" />
                    </div>
                }

                <button class="btn btn-primary w-100" @onclick="RegisterUser" disabled="@isLoading">
                    @if (isLoading) { <span>@L["SignUp_Btn_Processing"]</span> }
                    else { <span>@L["SignUp_Btn_Create"]</span> }
                </button>
            </div>
        }
        else
        {
            <div class="auth-form">
                <p class="text-center">@L["SignIn_SentTo"] <strong>@email</strong></p>
                <p class="text-center text-muted">@L["SignUp_VerifyHint"]</p>

                <div class="form-group">
                    <label for="signup-verify-code">@L["SignUp_Label_VerifCode"]</label>
                    <input id="signup-verify-code" type="text" class="form-control" @bind="verificationCode" placeholder="@L["SignIn_Placeholder_Code"]" maxlength="6" autocomplete="one-time-code" inputmode="numeric" />
                </div>

                <button class="btn btn-primary w-100" @onclick="VerifyAndCompleteRegistration" disabled="@isLoading">
                    @if (isLoading) { <span>@L["SignUp_Btn_Verifying"]</span> }
                    else { <span>@L["SignUp_Btn_Verify"]</span> }
                </button>

                <button class="btn btn-link w-100" @onclick="ResetVerification">@L["SignUp_StartOver"]</button>
            </div>
        }

        <div class="auth-footer">
            <p>@L["SignUp_AlreadyHave"] <a href="/signin">@L["SignUp_SignInLink"]</a></p>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string username = "";
    private string password = "";
    private string confirmPassword = "";
    private string preferredAuthMethod = "Both";
    private string verificationCode = "";
    private string tempUserId = "";
    private bool verificationSent = false;
    private bool isLoading = false;
    private string? errorMessage;
    private string? successMessage;

    private async Task RegisterUser()
    {
        errorMessage = null;
        successMessage = null;

        // Validate username - always required
        if (string.IsNullOrWhiteSpace(username))
        {
            errorMessage = L["SignUp_UsernameRequired"];
            return;
        }

        // Validate based on preferred auth method
        if (preferredAuthMethod == "Email" || preferredAuthMethod == "Both")
        {
            if (string.IsNullOrWhiteSpace(email))
            {
                errorMessage = L["SignUp_EmailRequired"];
                return;
            }
        }

        if (preferredAuthMethod == "Password" || preferredAuthMethod == "Both")
        {
            if (string.IsNullOrWhiteSpace(password))
            {
                errorMessage = L["SignUp_PasswordRequired2"];
                return;
            }

            if (password != confirmPassword)
            {
                errorMessage = L["SignUp_PasswordMismatch"];
                return;
            }
        }

        isLoading = true;
        try
        {
            // If email is provided, send verification
            if (!string.IsNullOrWhiteSpace(email))
            {
                var response = await ApiClient.SendRegistrationVerificationAsync(email, username, password, preferredAuthMethod, LangState.CurrentLanguageCode);
                if (response.Success && response.Data != null)
                {
                    tempUserId = response.Data.TempUserId;
                    verificationSent = true;
                    successMessage = L["SignUp_CodeSent"];
                }
                else
                {
                    errorMessage = response.Error ?? L["SignUp_Failed"];
                }
            }
            else
            {
                // No email - register directly (password-only without email)
                var response = await ApiClient.RegisterAsync(email, username, password, preferredAuthMethod, LangState.CurrentLanguageCode);
                if (response.Success && response.Data != null)
                {
                    Navigation.NavigateTo("/signin");
                }
                else
                {
                    errorMessage = response.Error ?? L["SignUp_Failed"];
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task VerifyAndCompleteRegistration()
    {
        errorMessage = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(verificationCode))
        {
            errorMessage = L["SignUp_EnterCode"];
            return;
        }

        isLoading = true;
        try
        {
            var response = await ApiClient.VerifyRegistrationAsync(tempUserId, verificationCode);
            if (response.Success && response.Data != null)
            {
                // Registration complete, redirect to sign in
                Navigation.NavigateTo("/signin");
            }
            else
            {
                errorMessage = response.Error ?? L["Reg_VerificationFailed"];
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ResetVerification()
    {
        verificationSent = false;
        verificationCode = "";
        tempUserId = "";
        errorMessage = null;
        successMessage = null;
    }
}

