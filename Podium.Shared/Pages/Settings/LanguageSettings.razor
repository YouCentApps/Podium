@page "/settings/language"
@inject LanguageStateService LangState
@inject AuthStateService AuthState
@inject IPodiumApiClient ApiClient
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SettingsRes> L
@inject IStringLocalizer<Common> LC

<PageTitle>Language Settings - Podium</PageTitle>

<div class="settings-form-container">
    <a href="/settings" class="back-link">&lsaquo; @LC["Btn_BackToSettings"]</a>

    <div class="settings-form-card">
        <h2>@L["LangSettings_Title"]</h2>
        <p class="subtitle">@L["LangSettings_Subtitle"]</p>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (isLoadingDbLang)
        {
            <div class="loading-spinner">
                <p>@LC["Loading"]</p>
            </div>
        }
        else
        {
            <div class="current-value">
                <strong>@L["LangSettings_Current"]</strong> @GetLanguageName(dbLanguageCode)
            </div>

            <div class="lang-options">
                @foreach (var lang in supportedLanguages)
                {
                    var isSelected = dbLanguageCode == lang.Code;
                    <div class="lang-option-card @(isSelected ? "selected" : "")" @onclick="() => SelectLanguage(lang.Code)">
                        <span class="lang-name">@lang.Name</span>
                        <button class="btn @(isSelected ? "btn-success" : "btn-primary") btn-sm" disabled="@(isSelected || isSaving)">
                            @if (isSaving && pendingCode == lang.Code)
                            {
                                <span>@L["LangSettings_Saving"]</span>
                            }
                            else if (isSelected)
                            {
                                <span>@L["LangSettings_Btn_Selected"]</span>
                            }
                            else
                            {
                                <span>@L["LangSettings_Btn_Select"]</span>
                            }
                        </button>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private bool isSaving = false;
    private bool isLoadingDbLang = true;
    private string pendingCode = "";
    private string? successMessage;
    private string dbLanguageCode = "en";

    private record LangOption(string Code, string Name);

    private List<LangOption> supportedLanguages = new();

    protected override async Task OnInitializedAsync()
    {
        var response = await ApiClient.GetLanguagesAsync();
        if (response.Success && response.Data != null)
        {
            supportedLanguages = response.Data
                .Select(l => new LangOption(l.Code, l.Name))
                .ToList();
        }
        else
        {
            // Fallback if API unreachable
            supportedLanguages = new()
            {
                new("en", "English"),
                new("fr", "Français"),
                new("ru", "Русский"),
            };
        }

        // Load the user's saved language from DB
        if (AuthState.IsAuthenticated)
        {
            try
            {
                var langResponse = await ApiClient.GetMyLanguageAsync();
                if (langResponse.Success && langResponse.Data != null)
                {
                    dbLanguageCode = langResponse.Data.LanguageCode;
                }
            }
            catch { /* fallback to default */ }
        }

        isLoadingDbLang = false;
    }

    private string GetLanguageName(string code) =>
        supportedLanguages.FirstOrDefault(l => l.Code == code)?.Name ?? code;

    private async Task SelectLanguage(string code)
    {
        if (dbLanguageCode == code || isSaving)
            return;

        isSaving = true;
        pendingCode = code;

        // Save to DB first
        if (AuthState.IsAuthenticated)
        {
            try { await ApiClient.UpdateMyLanguageAsync(code); }
            catch { /* will still apply locally */ }
        }

        dbLanguageCode = code;

        // Also apply immediately to the current session
        await LangState.SetLanguageAsync(code);

        try
        {
            await JSRuntime.InvokeVoidAsync("podiumCulture.set", code);
        }
        catch
        {
            // JS interop may not be available (MAUI)
        }

        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }
}
