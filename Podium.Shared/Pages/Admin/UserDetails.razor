@page "/admin/users/{UserId}"
@using Podium.Shared.Services.State
@using Podium.Shared.Services.Api
@using Podium.Shared.Models
@inject AuthStateService AuthState
@inject AdminStateService AdminState
@inject NavigationManager Navigation
@inject IPodiumApiClient ApiClient
@inject IStringLocalizer<AdminRes> L

<PageTitle>@L["Admin_UserDetails_AccountInfo"] - Admin</PageTitle>

<div class="admin-container">
    @if (loading)
    {
        <div class="loading">@L["Admin_Loading"]</div>
    }
    else if (user == null)
    {
        <div class="admin-error">
            <h2>@L["Admin_User_NotFound"]</h2>
            <p>@L["Admin_User_NotFound_Desc"]</p>
            <button class="btn btn-primary" @onclick="GoBack">@L["Admin_Btn_BackToUsers"]</button>
        </div>
    }
    else
    {
        <div class="admin-header">
            <div>
                <button class="btn btn-outline" @onclick="GoBack">&larr; @L["Admin_Btn_BackToUsers"]</button>
                <h1><span style="font-size: 1.2em;">&#128100;</span> @user.Username</h1>
                <p class="user-email">@user.Email</p>
            </div>
        </div>

        <div class="user-details-grid">
            <div class="detail-card">
                <h3>@L["Admin_UserDetails_AccountInfo"]</h3>
                <div class="detail-row">
                    <span class="detail-label">@L["Admin_UserDetails_UserId"]</span>
                    <span class="detail-value">@user.UserId</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">@L["Admin_Users_Col_Username"]:</span>
                    <span class="detail-value">@user.Username</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">@L["Admin_Users_Col_Email"]:</span>
                    <span class="detail-value">@user.Email</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">@L["Admin_Col_Status"]:</span>
                    <span class="badge @(user.IsActive ? "badge-success" : "badge-inactive")">
                        @(user.IsActive ? L["Admin_Status_Active"].Value : L["Admin_Status_Inactive"].Value)
                    </span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">@L["Admin_UserDetails_PreferredAuth"]</span>
                    <span class="detail-value">@user.PreferredAuthMethod</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">@L["Admin_Users_Col_Registered"]:</span>
                    <span class="detail-value">@user.CreatedDate.ToString("MMMM dd, yyyy")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">@L["Admin_Users_Col_LastLogin"]:</span>
                    <span class="detail-value">@(user.LastLoginDate?.ToString("MMMM dd, yyyy HH:mm") ?? L["Admin_Never"].Value)</span>
                </div>
            </div>

            @if (dependencies != null)
            {
                <div class="detail-card">
                    <h3>@L["Admin_UserDetails_Activity"]</h3>
                    <div class="detail-row">
                        <span class="detail-label">@L["Admin_UserDetails_Predictions"]</span>
                        <span class="detail-value">@dependencies.PredictionCount</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@L["Admin_UserDetails_AdminStatus"]</span>
                        <span class="badge @(dependencies.IsAdmin ? "badge-success" : "badge-inactive")">
                            @(dependencies.IsAdmin ? L["Admin_UserDetails_IsAdmin"].Value : L["Admin_UserDetails_NotAdmin"].Value)
                        </span>
                    </div>
                    @if (dependencies.HasDependencies)
                    {
                        <div class="alert alert-info" style="margin-top: 1rem;">
                            @L["Admin_UserDetails_HasDependencies"]
                        </div>
                    }
                </div>
            }
        </div>

        <div class="action-buttons">
            <button class="btn btn-primary" @onclick="EditUser">@L["Admin_Users_EditUser"]</button>
            @if (dependencies != null && dependencies.IsAdmin)
            {
                <a href="/admin/admins" class="btn btn-outline">@L["Admin_UserDetails_ManageAdminPriv"]</a>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public string UserId { get; set; } = string.Empty;

    private User? user = null;
    private UserDependencies? dependencies = null;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!AdminState.IsInitialized)
        {
            await AdminState.InitializeAsync();
        }

        if (!AdminState.IsAdmin)
        {
            Navigation.NavigateTo("/admin");
            return;
        }

        await LoadUserDetails();
    }

    private async Task LoadUserDetails()
    {
        loading = true;

        var userResponse = await ApiClient.GetUserAdminAsync(UserId);
        if (userResponse.Success && userResponse.Data != null)
        {
            user = userResponse.Data;
        }

        var depResponse = await ApiClient.GetUserDependenciesAsync(UserId);
        if (depResponse.Success && depResponse.Data != null)
        {
            dependencies = depResponse.Data;
        }

        loading = false;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin/users");
    }

    private void EditUser()
    {
        Navigation.NavigateTo($"/admin/users?editUserId={UserId}");
    }
}
