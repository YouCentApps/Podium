@page "/admin"
@using Podium.Shared.Services.State
@using Podium.Shared.Services.Api
@inject AuthStateService AuthState
@inject AdminStateService AdminState
@inject NavigationManager Navigation
@inject IPodiumApiClient ApiClient
@inject IStringLocalizer<AdminRes> L
@inject IStringLocalizer<Common> LC

<PageTitle>@L["Admin_Dashboard_Title"] - Podium</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    <div class="admin-container">
        <div class="admin-error">
            <h1><span style="font-size: 1.3em;">&#128274;</span> @L["Admin_AuthRequired"]</h1>
            <p>@L["Admin_AuthRequired_Desc"]</p>
            <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/signin"))">@LC["Nav_SignIn"]</button>
        </div>
    </div>
}
else if (!AdminState.IsAdmin)
{
    <div class="admin-container">
        <div class="admin-error">
            <h1><span style="font-size: 1.3em;">&#128737;</span> @L["Admin_AccessDenied"]</h1>
            <p>@L["Admin_NotAuthorized"]</p>
            <button class="btn btn-secondary" @onclick="@(() => Navigation.NavigateTo("/"))">@L["Admin_BackToHome"]</button>
        </div>
    </div>
}
else
{
    <div class="admin-container">
        <div class="admin-header">
            <h1><span style="font-size: 1.2em;">&#9881;</span> @L["Admin_Dashboard_Title"]</h1>
            <p>@L["Admin_Dashboard_Subtitle"]</p>
        </div>

        <div class="admin-cards">
            <a href="/admin/disciplines" class="admin-card">
                <div class="card-icon"><span style="font-size: 1.2em;">&#127950;&#65039;</span></div>
                <h2>@L["Admin_Disciplines_Title"]</h2>
                <p>@L["Admin_Disciplines_Desc"]</p>
            </a>

            <a href="/admin/series" class="admin-card">
                <div class="card-icon">&#127942;</div>
                <h2>@L["Admin_Series_Title"]</h2>
                <p>@L["Admin_Series_Desc"]</p>
            </a>

            <a href="/admin/seasons" class="admin-card">
                <div class="card-icon">&#128197;</div>
                <h2>@L["Admin_Seasons_Title"]</h2>
                <p>@L["Admin_Seasons_Desc"]</p>
            </a>

            <a href="/admin/competitors" class="admin-card">
                <div class="card-icon"><span style="font-size: 1.2em;">&#127933;&#65039;</span></div>
                <h2>@L["Admin_Competitors_Title"]</h2>
                <p>@L["Admin_Competitors_Desc"]</p>
            </a>

            <a href="/admin/events" class="admin-card">
                <div class="card-icon">&#127937;</div>
                <h2>@L["Admin_Events_Title"]</h2>
                <p>@L["Admin_Events_Desc"]</p>
            </a>

            <a href="/admin/results" class="admin-card">
                <div class="card-icon">&#128202;</div>
                <h2>@L["Admin_Results_Title"]</h2>
                <p>@L["Admin_Results_Desc"]</p>
            </a>

            <a href="/admin/users" class="admin-card">
                <div class="card-icon">&#128101;</div>
                <h2>@L["Admin_Users_Title"]</h2>
                <p>@L["Admin_Users_Desc"]</p>
            </a>

            @if (AdminState.CanManageAdmins)
            {
                <a href="/admin/admins" class="admin-card">
                    <div class="card-icon"><span style="font-size: 1.2em;">&#128737;&#65039;</span></div>
                    <h2>@L["Admin_Admins_Title"]</h2>
                    <p>@L["Admin_Admins_Desc"]</p>
                </a>
            }
        </div>

        @if (!string.IsNullOrEmpty(diagnosticMessage))
        {
            <div class="admin-diagnostics">
                <h2>[!] Quick Diagnostics</h2>
                <button class="btn btn-secondary" @onclick="CheckDuplicateSeasons">Check for Duplicate Active Seasons</button>
                <div class="diagnostic-result">@diagnosticMessage</div>
            </div>
        }
    </div>
}

@code {
    private string diagnosticMessage = "";

    protected override async Task OnInitializedAsync()
    {
        if (!AdminState.IsInitialized)
        {
            await AdminState.InitializeAsync();
        }

        AdminState.OnAdminStateChanged += StateHasChanged;
    }

    private async Task CheckDuplicateSeasons()
    {
        var response = await ApiClient.FindDuplicateActiveSeasonsAsync();
        diagnosticMessage = response.Success 
            ? response.Data?.Message ?? L["Admin_SaveSuccess"].Value 
            : string.Format(L["Admin_Error"].Value + ": {0}", response.Error);
        StateHasChanged();
    }

    public void Dispose()
    {
        AdminState.OnAdminStateChanged -= StateHasChanged;
    }
}
