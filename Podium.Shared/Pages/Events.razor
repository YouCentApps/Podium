@page "/series/{SeriesId}/events"
@inject IPodiumApiClient ApiClient
@inject NavigationManager Navigation
@inject IStringLocalizer<Predictions> L
@inject IStringLocalizer<Common> LC

<PageTitle>Select Event - Podium</PageTitle>

<div class="page-container">
    <nav class="breadcrumb">
        <a href="/disciplines">@L["SeriesSelection_Breadcrumb"]</a> / <a href="javascript:history.back()">@L["Events_Breadcrumb_Series"]</a> / @L["Events_Breadcrumb_Events"]
    </nav>

    <h1>@L["SeasonEvents_Title"]</h1>

    @if (isLoading)
    {
        <div class="loading-spinner">
            <p>@LC["Loading"]</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (events.Count == 0)
    {
        <div class="alert alert-info">
            @L["SeasonEvents_None"]
        </div>
    }
    else
    {
        <div class="event-grid">
            @foreach (var evt in events)
            {
                <div class="event-card" @onclick="() => SelectEvent(evt.Id, seasonId)">
                    <h3>@evt.DisplayName</h3>
                    <p>@evt.Location</p>
                    <p class="event-date">
                        <span class="event-icon">&#128197;</span> @evt.EventDate.ToString("MMM dd, yyyy HH:mm") UTC
                    </p>
                    @if (evt.CanAcceptPredictions)
                    {
                        <span style="color: var(--success-color); font-weight: 500;"><span class="status-icon">&#10003;</span> @L["SeasonEvents_OpenPredictions"]</span>
                    }
                    else
                    {
                        <span style="color: var(--text-light);">@L["SeasonEvents_Closed"]</span>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public string SeriesId { get; set; } = "";

    private List<Event> events = new();
    private string seasonId = "";
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadEvents();
    }

    private async Task LoadEvents()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            // First get the active season for this series
            var seasonResponse = await ApiClient.GetActiveSeasonAsync(SeriesId);
            if (!seasonResponse.Success || seasonResponse.Data == null)
            {
                errorMessage = L["Events_NoActiveSeason"];
                isLoading = false;
                return;
            }

            seasonId = seasonResponse.Data.Id;

            // Now get events for this season
            var eventsResponse = await ApiClient.GetUpcomingEventsAsync(seasonId);
            if (eventsResponse.Success && eventsResponse.Data != null)
            {
                events = eventsResponse.Data;
            }
            else
            {
                errorMessage = eventsResponse.Error ?? L["Events_LoadFailed"];
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectEvent(string eventId, string seasonId)
    {
        Navigation.NavigateTo($"/predict/{seasonId}/{eventId}");
    }
}
