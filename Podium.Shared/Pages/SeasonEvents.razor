@page "/season/{SeasonId}/events"
@inject IPodiumApiClient ApiClient
@inject NavigationManager Navigation
@inject IStringLocalizer<Predictions> L
@inject IStringLocalizer<Common> LC

<PageTitle>@L["SeasonEvents_Title"] - Podium</PageTitle>

<div class="page-container">
    <nav class="breadcrumb">
        <a href="/">@L["SeasonEvents_Breadcrumb"]</a> / @L["Events_Breadcrumb_Events"]
    </nav>

    <h1>@L["SeasonEvents_Title"]</h1>

    @if (isLoading)
    {
        <div class="loading-spinner">
            <p>@LC["Loading"]</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (events.Count == 0)
    {
        <div class="alert alert-info">
            @L["SeasonEvents_None"]
        </div>
    }
    else
    {
        <div class="event-grid">
            @foreach (var evt in events)
            {
                <div class="event-card" @onclick="() => SelectEvent(evt.Id, SeasonId)">
                    <h3>@evt.DisplayName</h3>
                    <p>@evt.Location</p>
                    <p class="event-date">
                        <span class="event-icon">&#128197;</span> @evt.EventDate.ToString("MMM dd, yyyy HH:mm") UTC
                    </p>
                    @if (evt.CanAcceptPredictions)
                    {
                        <span style="color: var(--success-color); font-weight: 500;"><span class="status-icon">&#10003;</span> @L["SeasonEvents_OpenPredictions"]</span>
                    }
                    else
                    {
                        <span style="color: var(--text-light);">@L["SeasonEvents_Closed"]</span>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public string SeasonId { get; set; } = "";

    private List<Event> events = new();
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadEvents();
    }

    private async Task LoadEvents()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            // Get events for this season
            var eventsResponse = await ApiClient.GetUpcomingEventsAsync(SeasonId);
            if (eventsResponse.Success && eventsResponse.Data != null)
            {
                events = eventsResponse.Data;
            }
            else
            {
                errorMessage = eventsResponse.Error ?? L["Events_LoadFailed"];
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectEvent(string eventId, string seasonId)
    {
        Navigation.NavigateTo($"/predict/{seasonId}/{eventId}");
    }
}
