@if (IsVisible)
{
    <div class="modal-overlay" @onclick="Cancel">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@Title</h3>
            </div>
            <div class="modal-body">
                <p>@Message</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="Cancel">@CancelText</button>
                <button class="btn btn-danger" @onclick="Confirm">@ConfirmText</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Title { get; set; } = "Confirm Action";
    [Parameter] public string Message { get; set; } = "Are you sure?";
    [Parameter] public string ConfirmText { get; set; } = "Confirm";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirm()
    {
        await OnConfirm.InvokeAsync();
    }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync();
    }
}

@code {
    [Inject] private IStringLocalizer<Common>? LC { get; set; }

    protected override void OnParametersSet()
    {
        // Provide localized defaults when not supplied by caller
        if (string.IsNullOrEmpty(ConfirmText))
        {
            ConfirmText = LC?["Btn_Confirm"].Value ?? "Confirm";
        }

        if (string.IsNullOrEmpty(CancelText))
        {
            CancelText = LC?["Btn_Cancel"].Value ?? "Cancel";
        }

        if (string.IsNullOrEmpty(Title))
        {
            Title = LC?["Confirm_Title"].Value ?? "Confirm Action";
        }

        if (string.IsNullOrEmpty(Message))
        {
            Message = LC?["Confirm_Message"].Value ?? "Are you sure?";
        }
    }
}
